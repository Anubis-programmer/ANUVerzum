{
  "name": "anu-verzum",
  "version": "2.4.1",
  "description": "A \"React-like\" UI library that supports JSX syntax, Redux-like state management, array-rendering, i18n, routing and many more.",
  "keywords": [
    "anu-verzum",
    "UI-library",
    "React-like",
    "JSX",
    "state-management",
    "routing",
    "i18n"
  ],
  "files": [
    "dist",
    "babel-preset.js",
    "webpack.config.js"
  ],
  "homepage": "https://github.com/Anubis-programmer/ANUVerzum#readme",
  "bugs": {
    "url": "https://github.com/Anubis-programmer/ANUVerzum/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anubis-programmer/ANUVerzum.git"
  },
  "license": "MIT",
  "author": "Anubis-programmer",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./testing": "./dist/testing/index.js",
    "./babel-preset": "./babel-preset.js",
    "./webpack.config": "./webpack.config.js"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "build": "npm run clean && babel src --out-dir dist --extensions \".ts\" --ignore \"src/testing/__tests__\" && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx": "^7.21.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "babel-loader": "^9.0.0",
    "html-webpack-plugin": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^5.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.21.0",
    "@babel/core": "^7.21.0",
    "@babel/preset-env": "^7.21.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-jest": "^29.7.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
