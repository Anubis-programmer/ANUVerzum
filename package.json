{
  "name": "anu-verzum",
  "version": "1.10.0",
  "description": "A \"React-like\" UI library that supports JSX syntax, Redux-like state management, array-rendering, i18n, routing and many more.",
  "keywords": [
    "anu-verzum",
    "UI-library",
    "React-like",
    "JSX",
    "state-management",
    "routing",
    "i18n"
  ],
  "files": [
    "dist",
    "babel-preset.js"
  ],
  "homepage": "https://github.com/Anubis-programmer/ANUVerzum#readme",
  "bugs": {
    "url": "https://github.com/Anubis-programmer/ANUVerzum/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anubis-programmer/ANUVerzum.git"
  },
  "license": "MIT",
  "author": "Anubis-programmer",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "build": "npm run clean && babel src --out-dir dist --extensions \".ts\" && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepare": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx": "^7.21.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.21.0",
    "@babel/core": "^7.21.0",
    "@babel/preset-env": "^7.21.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
